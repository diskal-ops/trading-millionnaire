# Frontend (Vite) — variables PUBLIQUES uniquement.
# La clé Gemini N'EST JAMAIS ici : elle vit dans l'Edge Function (supabase secrets).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Nom de l'Edge Function proxy (laisser tel quel sauf si renommée)
VITE_GEMINI_PROXY_FN=gemini-proxy
